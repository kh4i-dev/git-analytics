APP_NAME="Git Analytics"
ENVIRONMENT=development
APP_ENV=development
WORKSPACE_FEATURE_ENABLED=true
DEBUG=true
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./git_analytics.db
API_V1_PREFIX=/api/v1

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/auth/github/callback
SECRET_KEY=change-this-secret-key
# Generate with: python -c "from app.core.security import generate_encryption_key; print(generate_encryption_key())"
ENCRYPTION_KEY=

# BYOK keys are saved encrypted in the database. The values below are only for
# server-side Cloud AI preview configuration.
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-sonnet-4-20250514
# Optional OpenAI-compatible Cloud gateway such as OpenClaw. Keep these server-side.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
CLOUD_AI_PREVIEW_DAILY_LIMIT=30
